<% content_for :head do %>
  <meta name="turbo-visit-control" content="reload">
  <% if ENV["PAYPAL_CLIENT_ID"].present? %>
    <script
      src="https://www.paypal.com/sdk/js?client-id=<%= ENV["PAYPAL_CLIENT_ID"] %>&currency=USD&intent=capture"
      data-turbo-track="reload"></script>
  <% end %>
<% end %>

<section class="product-show">
  <div class="product-show-card"
       data-controller="paypal"
       data-paypal-client-id-value="<%= ENV["PAYPAL_CLIENT_ID"] %>"
       data-paypal-product-id-value="<%= @product.id %>"
       data-paypal-variant-select-id-value="variant_id"
       data-paypal-currency-value="USD">

    <h1><%= @product.name %></h1>

    <% if @product.image_key.present? %>
      <% @product.image_variant_keys.each_with_index do |key, index| %>
        <% proxy_url = image_proxy_url(key, width: 900, height: 900, fit: "inside", format: "webp") %>
        <% if proxy_url.present? %>
          <%= image_tag proxy_url,
            class: "product-main-image",
            alt: index.zero? ? @product.name : "#{@product.name} alternate",
            loading: (index.zero? ? "eager" : "lazy") %>
        <% end %>
      <% end %>
    <% end %>

    <p class="product-description"><%= @product.description %></p>

    <% priced_variants = @variants.select(&:price_available?) %>
    <% available_variants = priced_variants.select { |v| v.stock.present? && v.stock > 0 } %>
    <% default_price = available_variants.first&.effective_price || priced_variants.first&.effective_price || @product.price %>

    <% if @variants.any? %>
      <div class="variant-selector">
        <label for="variant_id">Choose option</label>

        <select id="variant_id">
          <% @variants.each do |variant| %>
            <% out_of_stock = variant.stock.blank? || variant.stock <= 0 %>
            <% price_missing = variant.price_available? == false %>
            <option
              value="<%= variant.id %>"
              data-price="<%= variant.effective_price if variant.price_available? %>"
              <%= "disabled" if out_of_stock || price_missing %>>
              <%= variant.name %>
              <% if out_of_stock %>
                (Sold out)
              <% elsif price_missing %>
                (Pricing pending)
              <% elsif variant.stock.present? %>
                (<%= variant.stock %> left)
              <% end %>
            </option>
          <% end %>
        </select>
      </div>
    <% end %>

    <% if @product.price_hidden? %>
      <p class="product-price">Coming Soon</p>
    <% elsif @variants.any? && priced_variants.empty? %>
      <p class="product-price">Pricing pending</p>
    <% elsif @variants.any? && available_variants.empty? %>
      <p class="product-price">Sold Out</p>
    <% elsif @variants.none? %>
      <p class="product-price">No options available</p>
    <% else %>
      <p class="product-price">
        <% if default_price.present? %>
          $<span id="display-price" data-paypal-target="price"><%= number_with_precision(default_price, precision: 2) %></span>
        <% else %>
          <span id="display-price" data-paypal-target="price">—</span>
        <% end %>
      </p>

      <div
        class="paypal-container"
        data-turbo="false">
        <div id="paypal-button-container" data-paypal-target="buttons"></div>
        <p class="paypal-status" data-paypal-target="status" aria-live="polite"></p>
      </div>
    <% end %>

    <%= link_to "Back to products", products_path,
          class: "back-link",
          data: { turbo: false } %>

  </div>
</section>
