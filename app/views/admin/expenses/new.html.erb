<section class="admin-shell">
  <div class="admin-page">
    <header class="admin-hero admin-hero--compact">
      <div>
        <p class="admin-kicker">Ledger</p>
        <h1 class="admin-title">Add expense</h1>
        <p class="admin-subtitle">Log out-of-pocket spend so you can reimburse it later.</p>
      </div>
      <%= link_to "Back to ledger", admin_expenses_path, class: "admin-secondary-link" %>
    </header>

    <%= render "form", expense: @expense, url: admin_expenses_path, submit_label: "Add expense" %>
  </div>
</section>
