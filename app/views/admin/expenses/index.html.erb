<section class="admin-shell">
  <div class="admin-page">
    <header class="admin-hero admin-hero--compact">
      <div>
        <p class="admin-kicker">Ledger</p>
        <h1 class="admin-title">Expenses &amp; payables</h1>
        <p class="admin-subtitle">Track out-of-pocket spend and who the business owes.</p>
      </div>
      <div class="admin-hero-actions">
        <%= link_to "New expense", new_admin_expense_path, class: "admin-primary-button" %>
        <%= link_to "Back to admin", admin_root_path, class: "admin-secondary-link" %>
      </div>
    </header>

    <div class="admin-card-grid">
      <div class="admin-card">
        <p class="admin-kicker">Totals</p>
        <p><strong>Total spent:</strong> <%= number_to_currency(@total_spent) %></p>
        <p><strong>Outstanding:</strong> <%= number_to_currency(@total_outstanding) %></p>
      </div>

      <div class="admin-card">
        <p class="admin-kicker">Outstanding by person</p>
        <% if @outstanding_by_person.present? %>
          <ul>
            <% @outstanding_by_person.each do |name, amount| %>
              <li>
                <strong><%= name %>:</strong> <%= number_to_currency(amount) %>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="empty-state">No outstanding reimbursements.</p>
        <% end %>
      </div>
    </div>

    <% if @expenses.any? %>
      <table class="admin-table">
        <thead>
          <tr>
            <th>Date</th>
            <th>Description</th>
            <th>Owed to</th>
            <th>Amount</th>
            <th>Status</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @expenses.each do |expense| %>
            <tr>
              <td><%= expense.spent_on.strftime("%Y-%m-%d") %></td>
              <td>
                <strong><%= expense.description %></strong>
                <% if expense.notes.present? %>
                  <div><small><%= expense.notes %></small></div>
                <% end %>
              </td>
              <td><%= expense.owed_to %></td>
              <td><%= number_to_currency(expense.amount) %></td>
              <td><%= expense.reimbursed? ? "Reimbursed" : "Owed" %></td>
              <td>
                <%= link_to "Edit", edit_admin_expense_path(expense) %> |
                <%= button_to "Delete", admin_expense_path(expense),
                              method: :delete,
                              form: { data: { turbo_confirm: "Delete this expense?" } },
                              class: "admin-link-button" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="empty-state">No expenses logged yet.</p>
    <% end %>
  </div>
</section>
