<section class="admin-shell">
  <div class="admin-page">
    <header class="admin-hero admin-hero--compact">
      <div>
        <p class="admin-kicker">Products</p>
        <h1 class="admin-title">Edit product</h1>
        <p class="admin-subtitle">Update details, pricing, and images in one place.</p>
      </div>
      <%= link_to "Back to admin", admin_root_path, class: "admin-secondary-link" %>
    </header>

    <% heroku_host = "pickledpiratesracing-prod-e5b7e4ec2418.herokuapp.com" %>
    <% on_heroku = request.host == heroku_host %>
    <% fields_disabled = Rails.env.production? && on_heroku %>

    <%= form_with model: @product,
                  url: admin_product_path(@product),
                  method: :patch,
                  local: true,
                  html: { multipart: true,
                          id: "admin-product-form",
                          data: { turbo: false },
                          class: "admin-form" } do |f| %>

      <% if Rails.env.production? && !on_heroku %>
        <div class="admin-card">
          <p class="admin-kicker">Uploads</p>
          <p>Uploads only work on the Heroku admin. Click the button to open the correct page, log in if prompted, then upload and save there. If you try to upload here, you will be redirected to Heroku and asked to log in again.</p>
          <%= link_to "Open Heroku upload page",
              "https://#{heroku_host}/admin/products/#{@product.id}/edit",
              class: "admin-primary-button",
              target: "_blank",
              rel: "noopener" %>
        </div>
      <% end %>
      <% if fields_disabled %>
        <div class="admin-card">
          <p class="admin-kicker">Uploads only</p>
          <p>This page is limited to image uploads. Edit product details on the main admin domain.</p>
        </div>
      <% end %>

    <div class="admin-form-grid">
        <div class="admin-field">
          <%= f.label :name %>
          <%= f.text_field :name, required: true, disabled: fields_disabled %>
        </div>

        <div class="admin-field">
          <%= f.label :slug %>
          <%= f.text_field :slug, disabled: fields_disabled %>
        </div>

        <div class="admin-field">
          <%= f.label :margin_percent, "Margin (%)" %>
          <%= f.number_field :margin_percent, step: 0.01, disabled: fields_disabled %>
        </div>

        <div class="admin-field">
          <%= f.label :handling_fee, "Handling fee" %>
          <%= f.number_field :handling_fee, step: 0.01, disabled: fields_disabled %>
        </div>

        <div class="admin-field">
          <%= f.label :featured %>
          <%= f.select :featured, [["Featured", true], ["Standard", false]], selected: @product.featured?, disabled: fields_disabled %>
        </div>

      <div class="admin-field">
        <%= f.label :description %>
        <%= f.text_area :description, rows: 4, disabled: fields_disabled %>
      </div>
    </div>

    <div class="admin-card">
      <p class="admin-kicker">Pricing status</p>
      <% if @product.price.present? %>
        <p><strong>Current price:</strong> <%= number_to_currency(@product.price) %></p>
      <% else %>
        <p><strong>Current price:</strong> —</p>
      <% end %>
      <p>Price is auto-calculated from vendor costs, margin, and handling fee.</p>

      <% missing = @product.product_variants.select(&:active?).select { |variant| variant.suggested_price.nil? } %>
      <% if missing.any? %>
        <p><strong>Missing pricing:</strong> <%= missing.map(&:name).join(", ") %></p>
      <% else %>
        <p><strong>Status:</strong> All variants have pricing.</p>
      <% end %>
    </div>

      <div class="admin-field admin-field-inline">
        <%= f.check_box :price_hidden, disabled: fields_disabled %>
        <%= f.label :price_hidden, "Hide price (show Coming Soon)" %>
      </div>

      <% if !Rails.env.production? || on_heroku %>
        <div class="admin-form-grid">
          <div class="admin-field">
            <label>Image type</label>
            <select name="image_type">
              <option value="main">Main</option>
              <option value="alt">Alt</option>
            </select>
          </div>

          <div class="admin-field">
            <%= f.label :image, "Upload image" %>
            <%= f.file_field :image %>
          </div>
        </div>
      <% end %>

    <% end %>

    <% if @product.product_variants.any? %>
      <div class="admin-card">
        <p class="admin-kicker">Variants</p>
        <table class="admin-table">
          <thead>
            <tr>
              <th>Variant</th>
              <th>Stock</th>
              <th>Active</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% @product.product_variants.each do |variant| %>
              <tr>
                <td><%= variant.name %></td>
                <td><%= variant.stock %></td>
                <td><%= variant.active? ? "Yes" : "No" %></td>
                <td><%= link_to "Edit", edit_admin_product_variant_path(variant) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
        <div class="admin-back">
          <%= link_to "Add variant", new_admin_product_variant_path %>
        </div>
      </div>
    <% else %>
      <div class="admin-card">
        <p class="admin-kicker">Variants</p>
        <p>No variants yet.</p>
        <div class="admin-back">
          <%= link_to "Add variant", new_admin_product_variant_path %>
        </div>
      </div>
    <% end %>

    <div class="admin-form-actions admin-form-actions--bottom">
      <button type="submit" form="admin-product-form" class="admin-primary-button">Save changes</button>
    </div>
  </div>
</section>
